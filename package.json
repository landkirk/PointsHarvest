{
  "name": "bingbot2",
  "version": "1.4.0",
  "private": true,
  "scripts": {
    "build": "tsc --noEmit && tsc -p tsconfig.build.json && npm run build:content && cp manifest.json dist/",
    "build:content": "esbuild src/content/rewards-content.ts src/content/search-content.ts --bundle --outdir=dist/content --platform=browser --target=es2022 && esbuild src/popup.html --loader:.html=copy --outdir=dist",
    "watch": "concurrently --names tsc,esbuild --prefix-colors blue,green \"tsc -p tsconfig.build.json --watch --preserveWatchOutput\" \"npm run watch:content\"",
    "watch:content": "concurrently \"esbuild src/content/rewards-content.ts src/content/search-content.ts --bundle --outdir=dist/content --platform=browser --target=es2022 --watch\" \"esbuild src/popup.html --loader:.html=copy --outdir=dist --watch\""
  },
  "devDependencies": {
    "@types/chrome": "^0.0.324",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.4",
    "typescript": "^5.8.2"
  }
}
