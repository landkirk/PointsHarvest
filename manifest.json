{
  "manifest_version": 3,
  "name": "PointsHarvest",
  "version": "2.2.0",
  "description": "Automates daily Bing Rewards searches and Explore activities",
  "permissions": ["tabs", "storage", "sidePanel", "notifications"],
  "icons": { "48": "icons/icon1024.png", "128": "icons/icon1024.png" },
  "host_permissions": [
    "https://*.bing.com/*",
    "https://r2.pointsharvest.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {},
  "side_panel": {
    "default_path": "ui/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://rewards.bing.com/*"],
      "js": ["content/rewards-content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.bing.com/*"],
      "js": ["content/search-content.js"],
      "run_at": "document_idle"
    }
  ]
}
